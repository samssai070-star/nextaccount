"""
NextAccount v2 — core/yayoi_export.py
承認済み仕訳を弥生インポート形式CSVに変換する。

弥生形式の列定義（25項目）:
  1: 伝票No     2: 日付      3: 借方科目   4: 借方補助
  5: 借方部門   6: 借方税区分 7: 借方金額   8: 借方消費税
  9: 貸方科目  10: 貸方補助  11: 貸方部門  12: 貸方税区分
 13: 貸方金額  14: 貸方消費税 15: 摘要     16: 番号
 17: 期日      18: タイプ    19: 生成元    20: 仕訳メモ
 21: 調整      22: 付箋1    23: 付箋2    24: (空)  25: (空)
"""

from __future__ import annotations
import io
import csv
import logging
from datetime import datetime

logger = logging.getLogger(__name__)

# 借方税区分（課税10%内税）
TAX_KUBUN_10 = "課税売上10%"
TAX_KUBUN_0  = "対象外"


def _tax_kubun(tax_amount: int, total: int) -> str:
    """税区分を返す"""
    if tax_amount > 0:
        return "課税仕入10%"
    return "対象外"


def build_yayoi_csv(events: list[dict]) -> bytes:
    """
    承認済みイベントリストを弥生インポート形式CSVのバイト列に変換する。

    Args:
        events: DB から取得した accounting_events のリスト

    Returns:
        CSV バイト列（Shift-JIS エンコード）
    """
    output = io.StringIO()
    writer = csv.writer(output, lineterminator="\r\n")

    for i, evt in enumerate(events, start=1):
        try:
            event_date = str(evt.get("event_date", "")).replace("-", "/")
            debit_account  = evt.get("debit_account", "消耗品費")
            credit_account = evt.get("credit_account", "未払費用")
            total_amount   = int(evt.get("amount", 0))
            tax_10         = int(evt.get("tax_10_amount", 0))
            counterparty   = evt.get("counterparty", "")
            employee       = evt.get("employee_name", "")
            event_id       = evt.get("event_id", "")
            invoice_no     = evt.get("invoice_number", "") or ""

            tax_kubun = _tax_kubun(tax_10, total_amount)
            taxable   = int(evt.get("taxable_10_amount", total_amount))

            # 摘要: 取引先 / 社員名 / T番号
            summary = counterparty
            if employee:
                summary += f" / {employee}"
            if invoice_no:
                summary += f" / {invoice_no}"

            # 貸方科目から（社員名）を除去
            credit_base = credit_account.split("（")[0].strip()

            row = [
                i,              # 1: 伝票No
                event_date,     # 2: 日付
                debit_account,  # 3: 借方科目
                "",             # 4: 借方補助
                "",             # 5: 借方部門
                tax_kubun,      # 6: 借方税区分
                taxable,        # 7: 借方金額（税抜）
                tax_10,         # 8: 借方消費税
                credit_base,    # 9: 貸方科目
                employee,       # 10: 貸方補助（社員名）
                "",             # 11: 貸方部門
                "対象外",       # 12: 貸方税区分
                total_amount,   # 13: 貸方金額
                0,              # 14: 貸方消費税
                summary,        # 15: 摘要
                event_id,       # 16: 番号
                "",             # 17: 期日
                "0",            # 18: タイプ（0=単一仕訳）
                "",             # 19: 生成元
                "",             # 20: 仕訳メモ
                "0",            # 21: 調整
                "",             # 22: 付箋1
                "",             # 23: 付箋2
                "",             # 24: 空
                "",             # 25: 空
            ]
            writer.writerow(row)

        except Exception as e:
            logger.error(f"CSV変換エラー ({evt.get('event_id')}): {e}")
            continue

    csv_str = output.getvalue()
    # 円簿・弥生は Shift-JIS を要求
    try:
        return csv_str.encode("shift_jis", errors="replace")
    except Exception:
        return csv_str.encode("utf-8")
