# ============================================================
# NextAccount v2 — 環境変数テンプレート
# cp config/.env.example .env  してから実際の値を入力してください
# .env は絶対に Git にコミットしないこと
# ============================================================

# ----- Slack -----
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-x-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- Google Cloud -----
# サービスアカウントキーのJSONファイルパス（クラウド環境では Secret Manager を推奨）
GOOGLE_APPLICATION_CREDENTIALS=/secrets/google_key.json

# ----- Google Sheets -----
# スプレッドシートURL末尾の ID 部分
# 例: https://docs.google.com/spreadsheets/d/1aBcD.../edit → 1aBcD...
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# ----- Database (Supabase / PostgreSQL) -----
# Supabase: Settings > Database > Connection String > URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ----- App Settings -----
TZ=Asia/Tokyo
LOG_LEVEL=INFO
ENVIRONMENT=production

# ----- Phase 2: Accounting Software (Optional) -----
# freee
# FREEE_CLIENT_ID=
# FREEE_CLIENT_SECRET=
# FREEE_COMPANY_ID=

# MFクラウド会計
# MF_CLIENT_ID=
# MF_CLIENT_SECRET=

# 弥生クラウド
# YAYOI_API_KEY=
